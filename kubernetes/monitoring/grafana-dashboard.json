      "id": 1,
      "title": "CBDC Network Throughput (TPS)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-datasource"
          },
          "editorMode": "code",
          "expr": "sum(rate(cbdc_transactions_total[1m]))",
          "legendFormat": "Global TPS",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "requests/s"
        }
      }
    },
    {
      "collapsed": false,
